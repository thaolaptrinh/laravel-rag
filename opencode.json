{
  "$schema": "https://opencode.ai/config.json",
  "model": "zai-coding-plan/glm-5-turbo",
  "small_model": "zai-coding-plan/glm-5-turbo",
  "instructions": ["./AGENTS.md", "./docs/ARCHITECTURE.md"],
  "formatter": {
    "pint": {
      "command": ["vendor/bin/pint", "$FILE"],
      "extensions": [".php"]
    }
  },
  "compaction": {
    "auto": true
  },
  "permission": {
    "bash": {
      "*": "ask",
      "composer *": "allow",
      "php *": "allow",
      "phpstan *": "allow",
      "pest *": "allow",
      "vendor/bin/*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git show*": "allow",
      "grep *": "allow",
      "find *": "allow",
      "ls *": "allow"
    },
    "edit": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow"
  },
  "agent": {
    "build": {
      "model": "zai-coding-plan/glm-5-turbo"
    },
    "plan": {
      "model": "zai-coding-plan/glm-5-turbo"
    }
  }
}
