{
  "$schema": "https://opencode.ai/config.json",
  "model": "zai-coding-plan/glm-5-turbo",
  "small_model": "zai-coding-plan/glm-5-turbo",
  "instructions": ["./AGENTS.md", "./docs/ARCHITECTURE.md"],
  "formatter": {
    "pint": {
      "command": ["vendor/bin/pint", "$FILE"],
      "extensions": [".php"]
    }
  },
  "compaction": {
    "auto": true
  },
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow"
  },
  "agent": {
    "build": {
      "model": "zai-coding-plan/glm-5-turbo"
    },
    "plan": {
      "model": "zai-coding-plan/glm-5-turbo"
    }
  }
}
